# Copier vers .env et remplir les valeurs.

BACKEND_HOST=127.0.0.1
BACKEND_PORT=8787

# Core : supabase = auth + bootstrap + progress + uploads (recommandé en prod)
CORE_DB_MODE=supabase

# Supabase (service role côté serveur uniquement — ne jamais exposer au front)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Snapshot plateforme (admin / migration) — table avec colonnes id, payload, updated_at
SUPABASE_PLATFORM_TABLE=platform_state
SUPABASE_PLATFORM_ID=primary

# Optionnel : si défini, GET/PUT /api/platform/state exigent l’en-tête x-admin-token
PLATFORM_ADMIN_TOKEN=

# Bucket Storage pour miniatures modules (défaut module-thumbnails)
SUPABASE_STORAGE_BUCKET=module-thumbnails

# URL du site vitrine si l’API est sur un autre host (ex. api.…) — requis pour la redirection e-book gratuit.
PUBLIC_SITE_ORIGIN=https://masterytelegram.fr

# Stripe — Checkout Session (GET /api/stripe/checkout-session?product=formation)
# L’e-book est gratuit sur le site ; ?product=ebook redirige vers PUBLIC_SITE_ORIGIN/#free-ebook (plus de paiement Stripe).
STRIPE_SECRET_KEY=
# Webhook signing secret (Stripe Dashboard → Webhooks → endpoint signing secret)
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_FORMATION=
# Optionnel : sinon URLs de retour déduites du Host (HTTPS derrière reverse proxy)
STRIPE_SUCCESS_URL=
STRIPE_CANCEL_URL=
